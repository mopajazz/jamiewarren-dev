---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
export async function getStaticPaths() {
  const work = await getCollection('work');
  return work.map(w => ({ params: { slug: w.slug }, props: { entry: w } }));
}
const { entry } = Astro.props;
const { Content } = await entry.render();
---
<Base title={`${entry.data.title} — Jamie Warren`} description={entry.data.summary}>
  <article class="study">
    <p class="eyebrow">Case study // Jamie Warren</p>
    <h1>{entry.data.title}</h1>
    {entry.data.link && <p><a href={entry.data.link}>View the live artifact</a></p>}
    {entry.data.media && (
      <figure class="artifact-figure">
        <img src={entry.data.media.src} alt={entry.data.media.alt} loading="lazy" decoding="async" />
        {entry.data.media.caption && <figcaption>{entry.data.media.caption}</figcaption>}
      </figure>
    )}
    <Content />
    <p style="margin-top:3rem;"><a href="/work/">← All case studies</a></p>
  </article>
</Base>
